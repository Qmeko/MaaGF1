import os
import sys
import subprocess

# =========================================================================
# PRE-BUILD STEP: Generate Version Info & Offsets (CMake CONFIGURE_FILE Equivalent)
# =========================================================================
print("[*] SCons: Executing pre-build steps...")
gen_script = os.path.join('mk', 'gen_offsets.py')
if os.path.exists(gen_script):
    try:
        subprocess.check_call([sys.executable, gen_script])
    except subprocess.CalledProcessError as e:
        print(f"[-] Pre-build script failed with code {e.returncode}")
        Exit(1)
else:
    print(f"[-] Pre-build script {gen_script} not found! Skipping generation.")

print("-" * 50)

# =========================================================================
# SCONS ENVIRONMENT SETUP
# =========================================================================
env = Environment(TARGET_ARCH='amd64')

# Fetch the mode argument, default to 'release'
mode = ARGUMENTS.get('mode', 'release')

if mode == 'debug':
    # Debug mode: Disable optimization (/Od), inject macro
    env.Append(CCFLAGS=['/Od', '/EHsc', '/W3'])
    env.Append(CPPDEFINES=['ENABLE_DEBUG_CONSOLE'])
else:
    # Release mode: Maximize speed optimization (/O2)
    env.Append(CCFLAGS=['/O2', '/EHsc', '/W3'])

# Include
env.Append(CPPPATH=[
    '#lib/minhook/include',
    '#src'
])

# SRC File
sources = [
    'src/main.cpp',
    'lib/minhook/src/buffer.c',
    'lib/minhook/src/hook.c',
    'lib/minhook/src/trampoline.c',
    'lib/minhook/src/hde/hde64.c'
]

# Output DLL (lib) to `build/version`
dll = env.SharedLibrary(target='build/version', source=sources)

# Auto clean
env.Clean(dll, 'build')